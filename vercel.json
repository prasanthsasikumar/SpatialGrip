{
  "buildCommand": "",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/read", "destination": "/read.html" },
    { "source": "/show", "destination": "/show.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
