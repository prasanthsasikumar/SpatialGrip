{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/read",  "dest": "/public/read.html" },
    { "src": "/show",  "dest": "/public/show.html" },
    { "src": "/js/(.*)", "dest": "/public/js/$1" },
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)",  "dest": "/public/$1" }
  ]
}
